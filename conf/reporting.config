/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Nextflow execution reports (timeline, report, trace, DAG)
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Kept in a separate file that is only `includeConfig`-ed once `outdir` has a
    value (e.g. from a profile). `enabled` is evaluated eagerly when the config
    is parsed, so it must be resolved after `outdir` is set - otherwise the
    observers would write to a stray `null/pipeline_info` directory.
*/

timeline {
    enabled                  = true
    file                     = "${params.outdir}/pipeline_info/execution_timeline.html"
}

report {
    enabled                  = true
    file                     = "${params.outdir}/pipeline_info/execution_report.html"
}

trace {
    enabled                  = true
    file                     = "${params.outdir}/pipeline_info/execution_trace.txt"
}

dag {
    enabled                  = true
    file                     = "${params.outdir}/pipeline_info/pipeline_dag.html"
}
