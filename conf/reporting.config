/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Nextflow execution reports (timeline, report, trace, DAG)
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Included globally from `nextflow.config`, so every run - not just the test
    profile - gets execution reports. The `file` paths are lazy GStrings, so
    `--outdir` supplied on the command line resolves correctly. A run with no
    `outdir` at all is rejected up-front by the guard in `main.nf`, before any
    observer would write to a stray `null/pipeline_info` directory.
*/

timeline {
    enabled                  = true
    overwrite                = true
    file                     = "${params.outdir}/pipeline_info/execution_timeline.html"
}

report {
    enabled                  = true
    overwrite                = true
    file                     = "${params.outdir}/pipeline_info/execution_report.html"
}

trace {
    enabled                  = true
    overwrite                = true
    file                     = "${params.outdir}/pipeline_info/execution_trace.txt"
}

dag {
    enabled                  = true
    overwrite                = true
    file                     = "${params.outdir}/pipeline_info/pipeline_dag.html"
}
