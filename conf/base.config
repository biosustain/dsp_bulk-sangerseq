params {
    // `outdir` has no default: it is a required parameter (see nextflow_schema.json).
    // Provide it via `--outdir <dir>` or a profile (e.g. `-profile test`).
    outdir                   = null
    publish_dir_mode         = 'copy'

    // Input data (samplesheet, reference_fasta, data_dir) is not defaulted here;
    // provide it via -profile test or on the command line.

    trim_left                = 50
    trim_right               = 50
    trim_stringency_decompose = 0
    trim_stringency_align    = 0
    trim_stringency_assemble = 4

    tracy_image              = 'geargenomics/tracy:latest'
    container_platform       = 'linux/amd64'

    // VueGen report. `vuegen` (and its `quarto-cli` dependency, needed for the
    // html report type) is pip-installed at runtime into the base python image,
    // so no dedicated container has to be published.
    vuegen_image             = 'python:3.12'
    vuegen_version           = '0.6.0'
    vuegen_report_type       = 'html'
}

process {
    errorStrategy            = 'terminate'
    cpus                     = 1
    memory                   = '4 GB'
    time                     = '4h'
}

docker {
    enabled                  = false
    runOptions               = '--platform linux/amd64'
}
