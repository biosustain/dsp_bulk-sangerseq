params {
    outdir                   = 'outdir'

    // Input data (samplesheet, reference_fasta, data_dir) is not defaulted here;
    // provide it via -profile test or on the command line.

    trim_left                = 50
    trim_right               = 50
    trim_stringency_decompose = 0
    trim_stringency_align    = 0
    trim_stringency_assemble = 4

    tracy_image              = 'geargenomics/tracy:latest'
    container_platform       = 'linux/amd64'
}

process {
    errorStrategy            = 'terminate'
    cpus                     = 1
    memory                   = '4 GB'
    time                     = '4h'
}

docker {
    enabled                  = false
    runOptions               = '--platform linux/amd64'
}
