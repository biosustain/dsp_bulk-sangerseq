/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Config file for defining per-process options (publishDir, ext.args, etc.)
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Publishing is centralised here (nf-core convention) rather than hardcoded in
    each module, so modules stay portable and the publish mode is controlled by
    `params.publish_dir_mode`.
*/

process {

    // Intermediate staging step - nothing to publish.
    withName: PREPARE_INPUTS {
        publishDir = [enabled: false]
    }

    withName: TRACY_DECOMPOSE {
        publishDir = [path: { "${params.outdir}/decompose" }, mode: params.publish_dir_mode]
    }

    withName: TRACY_ALIGN {
        publishDir = [path: { "${params.outdir}/align" }, mode: params.publish_dir_mode]
    }

    withName: TRACY_DECOMPOSE_POSTPROCESS {
        publishDir = [path: { "${params.outdir}" }, mode: params.publish_dir_mode, pattern: '*.csv']
    }

    withName: TRACY_ASSEMBLE {
        publishDir = [path: { "${params.outdir}/assemble" }, mode: params.publish_dir_mode]
    }

    // Publishes each rendered viewer next to its source outputs, keyed by the
    // `section` input tag ('align' / 'decompose'). The two aliased invocations
    // (TRACY_RENDER_ALIGN / TRACY_RENDER_DECOMPOSE) share this config.
    withName: 'TRACY_RENDER_ALIGN|TRACY_RENDER_DECOMPOSE' {
        publishDir = [path: { "${params.outdir}/${section}" }, mode: params.publish_dir_mode, pattern: '*.html']
    }

    // Publishes the whole `vuegen_report/` tree (section structure + rendered
    // report) to `${outdir}/vuegen_report`.
    withName: VUEGEN_REPORT {
        publishDir = [path: { "${params.outdir}" }, mode: params.publish_dir_mode]
    }
}
