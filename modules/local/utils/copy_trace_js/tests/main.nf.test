nextflow_process {

    name "Test Process COPY_TRACE_JS"
    script "modules/local/utils/copy_trace_js/main.nf"
    process "COPY_TRACE_JS"

    tag "modules"
    tag "utils"

    test("Should stage the trace viewer JS as traceView.js") {

        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = file("${projectDir}/static/traceView.js")
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert process.out.get(0).size() == 1 },
                { assert process.out.get(0).get(0).endsWith("traceView.js") },
                { assert path(process.out.get(0).get(0)).exists() }
            )
        }
    }
}
