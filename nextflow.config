includeConfig 'conf/base.config'
includeConfig 'conf/modules.config'

params {
    input                    = 'data/test_data_1/samplesheet_test_data_1_multi_ref_grouping.csv'
    custom_config_version    = 'master'
    custom_config_base       = "https://raw.githubusercontent.com/biosustain/configs/${params.custom_config_version}"
}

timeline {
    enabled                  = true
    file                     = "${params.outdir}/pipeline_info/execution_timeline.html"
}

report {
    enabled                  = true
    file                     = "${params.outdir}/pipeline_info/execution_report.html"
}

trace {
    enabled                  = true
    file                     = "${params.outdir}/pipeline_info/execution_trace.txt"
}

dag {
    enabled                  = true
    file                     = "${params.outdir}/pipeline_info/pipeline_dag.html"
}

profiles {
    test {
        includeConfig 'conf/test.config'
    }

    docker {
        docker.enabled        = true
        singularity.enabled   = false
    }
}

manifest {
    name                      = 'biosustain/dsp_bulk-sangerseq'
    author                    = 'biosustain'
    homePage                  = 'https://github.com/biosustain/dsp_bulk-sangerseq'
    description               = 'Nextflow pipeline for bulk Sanger sequencing analysis using Tracy'
    mainScript                = 'main.nf'
    nextflowVersion           = '!>=23.10.0'
    version                   = '1.1.0-dev'
    defaultBranch             = 'main'
}
