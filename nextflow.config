/*
================================================================================
    Nextflow Configuration File for Tracy Sanger Sequencing Pipeline
================================================================================
*/

// Global default parameters, transpiled from config.yaml
params {
    // Input/output directories
    input_dir                  = 'data/sanger_seq'
    outdir                     = 'outdir/sanger_seq'
    samplesheet               = 'data/sanger_seq/samplesheet.csv'
    
    trim_left                 = 50
    trim_right                = 200
    
    // Docker configuration
    tracy_image               = 'geargenomics/tracy:latest'
    container_platform        = 'linux/amd64'
    
    // Processing options
    mode                      = 'auto'  // 'samplesheet', 'directory', or 'auto'
    reference                 = null     // Reference file for directory mode
}

// Container configuration
docker {
    enabled                   = true
    runOptions                = '--platform linux/amd64'
}

// Process configuration
process {
    // Container settings
    container                 = params.tracy_image
}

// Execution profiles
profiles {
    docker {
        docker.enabled        = true
        singularity.enabled   = false
    }
}

// Manifest
manifest {
    name                      = 'dsp_bulk-sangerseq'
    author                    = 'biosustain'
    homePage                  = 'https://github.com/biosustain/dsp_bulk-sangerseq'
    description               = 'Nextflow pipeline for bulk Sanger sequencing analysis using Tracy'
    mainScript                = 'main.nf'
    nextflowVersion           = '!>=21.10.3'
    version                   = '1.0.0'
    defaultBranch             = 'main'
}
